  bash -y $(curl -L https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh)
  conda install numpy
  touch ~/hello.py
  echo "print('hello world')" >> ~/hello.py

%test
  # test to run to ensure working environment
  exit 0

%runscript
